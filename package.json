{
  "name": "node_docker",
  "version": "1.0.0",
  "description": "A simple dockerized node application",
  "main": "index.js",
  "scripts": {
    "start": "node main",
    "dev": "nodemon -L main",
    "docker-compose-down": "docker-compose -f './docker-compose.yml' down",
    "docker-compose-up:dev": "docker-compose -f './docker-compose.yml' up -d --build api-dev",
    "docker:dev": "npm run docker-compose-down; npm run docker-compose-up:dev; docker-compose logs -f api-dev"
  },
  "keywords": [
    "docker",
    "node.js",
    "express",
    "desktop-docker"
  ],
  "author": "Kizito917",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "nodemon": "^2.0.7"
  }
}
